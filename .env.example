# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://your-app-url.com"

# GEMINI_API_KEY: Google AI Studio API key for the Coach IA route.
# Currently the coach route is offline (keyword-matcher) — wire this when AI is enabled.
GEMINI_API_KEY="your_gemini_api_key_here"

# SUPABASE_URL: Supabase project URL (found in Project Settings > API).
SUPABASE_URL="https://your-project-id.supabase.co"

# SUPABASE_ANON_KEY: Supabase anonymous (public) key.
# Safe to expose to the client.
SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# SUPABASE_SERVICE_ROLE_KEY: Supabase service role key.
# NEVER expose to the client — server-side only.
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"
